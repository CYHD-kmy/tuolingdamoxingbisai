# ── LLM API ──────────────────────────────
# 必填: DeepSeek API Key (https://platform.deepseek.com)
LLM_API_KEY=sk-xxx

# 可选: 模型配置
LLM_QUICK_MODEL=deepseek-chat
LLM_DEEP_MODEL=deepseek-reasoner
LLM_BASE_URL=https://api.deepseek.com
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# ── 数据源 ──────────────────────────────
# 可选: Tushare Token (https://tushare.pro)
TUSHARE_TOKEN=
